    {
      "parameters": {
        "fields": {
          "values": [
            { "name": "customer_name", "stringValue": "={{ $json.body?.customer_name ?? $json.customer_name }}" },
            { "name": "email", "stringValue": "={{ $json.body?.email ?? $json.email }}" },
            { "name": "message", "stringValue": "={{ $json.body?.message ?? $json.message }}" },
            { "name": "category", "stringValue": "={{ $json.body?.category ?? $json.category }}" }
          ]
        },
        "options": {}
      },
      "id": "ee92afbe-ab59-4e10-b39e-09e264190f83",
      "name": "Extract Fields",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "Bearer YOUR_GROQ_API_KEY_HERE" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a customer support triage agent. Analyze the customer message and respond ONLY with a valid JSON object. No extra text, no markdown. Format: {\\\"priority\\\": \\\"high\\\", \\\"department\\\": \\\"billing\\\", \\\"summary\\\": \\\"brief summary\\\", \\\"suggested_action\\\": \\\"action to take\\\"}. Priority: high, medium, or low. Department: billing, technical, or general.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Customer: {{ $json.customer_name }}\\nEmail: {{ $json.email }}\\nMessage: {{ $json.message }}\\nCategory: {{ $json.category }}\\n\\nTriage this and return only JSON.\"\n    }\n  ],\n  \"temperature\": 0.2,\n  \"max_tokens\": 150\n}",
        "options": {}
      },
      "id": "3601313d-a688-45e7-b5b0-d82140d2476d",
      "name": "Groq AI Triage",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.choices[0].message.content;\nlet parsed;\ntry {\n  const clean = raw.replace(/```json|```/g, '').trim();\n  parsed = JSON.parse(clean);\n} catch (e) {\n  parsed = { priority: 'medium', department: 'general', summary: 'Could not parse AI response', suggested_action: 'Manual review needed' };\n}\nconst prev = $('Extract Fields').item.json;\nreturn {\n  Timestamp: new Date().toISOString(),\n  'Customer Name': (prev.customer_name || 'Unknown').replace(/^=/, ''),\n  Email: (prev.email || 'no-email@example.com').replace(/^=/, ''),\n  Priority: (parsed.priority || 'medium').toUpperCase(),\n  Department: parsed.department || 'general',\n  Summary: parsed.summary || 'No summary',\n  'Suggested Action': parsed.suggested_action || 'Review manually',\n  'Original Message': (prev.message || '').replace(/^=/, ''),\n  priority_lower: (parsed.priority || 'medium').toLowerCase()\n};"
      },
      "id": "24105f3b-9f98-437c-aba5-55bc456dfd6a",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "loose" },
                "conditions": [
                  {
                    "leftValue": "={{ $json.priority_lower }}",
                    "rightValue": "high",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "High"
            },
            {
              "conditions": {
                "options": { "caseSensitive": false, "leftValue": "", "typeValidation": "loose" },
                "conditions": [
                  {
                    "leftValue": "={{ $json.priority_lower }}",
                    "rightValue": "medium",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
